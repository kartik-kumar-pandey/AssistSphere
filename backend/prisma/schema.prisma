generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENT
  CUSTOMER
  ADMIN
}

enum SessionStatus {
  ACTIVE
  ENDED
}

enum RecordingStatus {
  IN_PROGRESS
  PROCESSING
  READY
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentSessions Session[] @relation("AgentSessions")
}

model Session {
  id          String        @id @default(cuid())
  status      SessionStatus @default(ACTIVE)
  inviteToken String        @unique
  agentName   String?
  agentUserId String?
  agentUser   User?         @relation("AgentSessions", fields: [agentUserId], references: [id])
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  participants Participant[]
  messages     Message[]
  events       Event[]
  recordings   Recording[]
  files        SessionFile[]
  whiteboard   WhiteboardSnapshot?

  @@index([status])
  @@index([inviteToken])
}

model Participant {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name        String
  role        Role
  socketId    String?
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
  durationSec Int?

  @@index([sessionId])
}

model Message {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderName String
  senderRole Role
  text       String?
  fileUrl    String?
  fileName   String?
  fileMime   String?
  createdAt  DateTime @default(now())

  @@index([sessionId])
}

model Event {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model Recording {
  id               String          @id @default(cuid())
  sessionId        String
  session          Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status           RecordingStatus @default(IN_PROGRESS)
  filePath         String?
  fileUrl          String?
  startedAt        DateTime        @default(now())
  endedAt          DateTime?
  // Encryption metadata (AES-256-GCM)
  encryptionKeyEnc String?         // per-recording AES key, itself encrypted by the master key (hex)
  encryptionIv     String?         // 12-byte IV used during encryption (hex)
  encryptionTag    String?         // 16-byte GCM auth tag (hex)
  encrypted        Boolean         @default(false)

  @@index([sessionId])
}

model SessionFile {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  filename   String
  originalName String
  uploader   String
  uploaderRole Role
  url        String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  @@index([sessionId])
}

model WhiteboardSnapshot {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  elements  Json     @default("[]")
  updatedAt DateTime @updatedAt
}

model BrandingSettings {
  id            String   @id @default("default")
  appName       String   @default("AssistSphere")
  primaryColor  String   @default("#4f46e5")
  primaryHover  String   @default("#4338ca")
  logoUrl       String?
  logoDarkUrl   String?
  updatedAt     DateTime @updatedAt
}
