# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT secret (generate a strong random string)
JWT_SECRET="change-this-to-a-long-random-secret-key"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin credentials (simple auth for admin dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Agent secret (optional - agents enter this to create sessions)
AGENT_SECRET=agent-secret-key

# mediasoup WebRTC
# Use your LAN IP when testing across devices (e.g. 192.168.1.7). Use 127.0.0.1 for same-machine only.
MEDIASOUP_ANNOUNCED_IP=
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# Reconnect grace period (ms)
RECONNECT_GRACE_MS=30000

# Recording encryption master key (KEK — key-encryption-key)
# This wraps the per-recording AES-256-GCM data keys stored in the database.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET. Without it, encrypted recordings cannot be decrypted.
RECORDING_MASTER_KEY=replace-with-64-char-hex-string
