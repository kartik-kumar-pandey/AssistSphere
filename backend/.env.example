# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT secret (generate a strong random string)
JWT_SECRET="change-this-to-a-long-random-secret-key"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Admin credentials (simple auth for admin dashboard)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Agent secret (optional - agents enter this to create sessions)
AGENT_SECRET=agent-secret-key

# mediasoup WebRTC
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# Reconnect grace period (ms)
RECONNECT_GRACE_MS=30000
